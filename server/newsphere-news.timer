[Unit]
Description=Run the Newsphere news update every 15 minutes

[Timer]
# First run a couple minutes after boot, then every 15 minutes (matching
# GDELT's ~15-minute update cadence — faster would just re-fetch identical data).
OnBootSec=2min
OnUnitActiveSec=15min
AccuracySec=1min
Persistent=true

[Install]
WantedBy=timers.target
